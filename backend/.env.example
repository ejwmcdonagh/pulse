# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in your Supabase project: Settings → API
# If self-hosting Postgres instead, see README § "Alternative databases"
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── NVD (National Vulnerability Database) ─────────────────────────────────────
# Optional. Without a key, the NVD API allows ~5 requests per 30 seconds.
# Register free at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ── Ingestion schedule (cron expressions, UTC) ────────────────────────────────
# Leave blank to use the defaults defined in scheduler.py
CISA_KEV_CRON=0 6 * * *
CISA_ADVISORIES_CRON=0 */6 * * *
NCSC_CRON=0 */6 * * *
NVD_CRON=0 7 * * *

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
